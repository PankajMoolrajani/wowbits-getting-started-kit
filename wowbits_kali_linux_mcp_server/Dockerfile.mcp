# Dockerfile.mcp — lightweight container for the FastMCP HTTP server
# This is NOT the Kali container. It only runs mcp_server/server.py.
# It talks to the kali-api container over the Docker internal network.

FROM python:3.12-slim

WORKDIR /app

# Install MCP server dependencies only (no Kali tools needed here)
RUN pip install --no-cache-dir fastmcp requests

# Copy only the MCP server code
COPY mcp_server/ /app/mcp_server/

ENV PYTHONPATH=/app
ENV KALI_API_URL=http://kali-api:5000
ENV MCP_HOST=0.0.0.0
ENV MCP_PORT=8765
ENV LOG_LEVEL=INFO

EXPOSE 8765

CMD ["python3", "/app/mcp_server/server.py"]
